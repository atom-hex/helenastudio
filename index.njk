---
layout: _layouts/base.njk
title: Home
---
<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    padding: 4rem 0 5.5rem;
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-eyebrow {
    display: block;
    font-size: 0.6rem;
    font-weight: 300;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    max-width: 380px;
  }

  .hero-heading {
    font-family: var(--font-serif);
    font-size: clamp(3.25rem, 8vw, 6.5rem);
    font-weight: 300;
    line-height: 1.0;
    color: var(--text-1);
    margin-bottom: 2.25rem;
    letter-spacing: -0.01em;
  }

  .hero-heading em {
    font-style: italic;
    font-weight: 300;
    color: var(--accent);
  }

  .hero-sub {
    font-size: 0.98rem;
    font-weight: 300;
    color: var(--text-2);
    line-height: 1.95;
    max-width: 500px;
    letter-spacing: 0.02em;
  }

  /* ── Journal section ─────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .section-label {
    font-size: 0.62rem;
    font-weight: 300;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--text-3);
    white-space: nowrap;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── Article cards ───────────────────────────────────── */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .article-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.3s, box-shadow 0.3s;
    overflow: hidden;
  }

  /* Left accent bar — rises on hover */
  .article-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.4s ease;
  }

  .article-card:hover {
    border-color: rgba(140, 95, 24, 0.4);
    box-shadow: 0 6px 36px rgba(140, 95, 24, 0.09), 0 1px 6px rgba(12, 10, 7, 0.05);
  }

  .article-card:hover::before { transform: scaleY(1); }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .card-tag {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-rose);
    border: 1px solid var(--border-rose);
    padding: 0.2rem 0.6rem;
    border-radius: 1px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text-1);
    line-height: 1.2;
    margin-bottom: 0.85rem;
    letter-spacing: 0.01em;
  }

  .card-summary {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-2);
    line-height: 1.75;
    flex: 1;
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .card-date {
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.14em;
    color: var(--text-3);
    text-transform: uppercase;
  }

  .card-read {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    transition: letter-spacing 0.35s ease;
  }

  .article-card:hover .card-read { letter-spacing: 0.22em; }

  .empty-state {
    padding: 3rem 0;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-style: italic;
    font-weight: 300;
    color: var(--text-3);
  }

  /* ── Services ───────────────────────────────────────────── */
  .services-section {
    margin-bottom: 5rem;
  }

  .service-block {
    display: flex;
    flex-direction: column;
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .service-block:first-of-type { padding-top: 0; }
  .service-block:last-of-type { border-bottom: none; }

  .service-number {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: rgba(140, 95, 24, 0.22);
    line-height: 1;
    margin-bottom: 0.5rem;
    grid-column: 1;
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3.25rem);
    font-weight: 300;
    color: var(--text-1);
    line-height: 1.05;
    letter-spacing: 0.01em;
    margin: 0 0 1.25rem;
    grid-column: 1;
  }

  .service-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    column-gap: 5rem;
    align-items: start;
  }

  .service-subtitle {
    display: block;
    font-size: 0.68rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-rose);
    margin-bottom: 1.75rem;
    grid-column: 1;
  }

  .service-desc {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-2);
    line-height: 1.85;
    letter-spacing: 0.01em;
    margin-bottom: 1.75rem;
    grid-column: 1;
  }

  .service-cta-wrap {
    grid-column: 1;
  }

  .service-includes {
    list-style: none;
    margin-bottom: 2rem;
    grid-column: 2;
    grid-row: 1 / -1;
  }

  .service-includes li {
    font-size: 0.92rem;
    font-weight: 400;
    color: var(--text-2);
    letter-spacing: 0.01em;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .service-includes li::before {
    content: '';
    width: 18px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .service-cta {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-1);
    text-decoration: none;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--accent);
    transition: color 0.25s, letter-spacing 0.35s ease;
    grid-column: 1;
  }

  .service-cta:hover {
    color: var(--accent);
    letter-spacing: 0.28em;
  }

  @media (max-width: 900px) {
    .service-block { padding: 3rem 0; }
    .service-content { grid-template-columns: 1fr; column-gap: 0; }
    .service-number, .service-title, .service-subtitle, .service-desc, .service-cta { grid-column: 1; }
    .service-includes { grid-column: 1; grid-row: auto; }
  }

  /* ── About ───────────────────────────────────────────── */
  .about-section {
    margin-bottom: 5rem;
  }

  .about-content {
  }

  .about-text {
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text-2);
    line-height: 1.85;
    letter-spacing: 0.01em;
  }

  .about-text p { margin-bottom: 1.4rem; }

  @media (max-width: 640px) {
    .articles-grid { grid-template-columns: 1fr; }
    .hero { padding: 2rem 0 3rem; margin-bottom: 3rem; }
  }
</style>

<section class="hero">
  <span class="hero-eyebrow" data-i18n="tagline">Build &middot; Design &middot; Project Management</span>
  <h1 class="hero-heading">
    <span data-i18n="heroLine1">Built with</span><br>
    <em data-i18n="heroEm">precision and purpose.</em>
  </h1>
  <p class="hero-sub" data-i18n="heroSub">{{ site.description }}</p>
</section>

<section class="services-section">
  <div class="section-header">
    <span class="section-label" data-i18n="services">Services</span>
    <div class="section-rule"></div>
  </div>

  <div class="service-block">
    <div class="service-content">
      <span class="service-number">01</span>
      <h2 class="service-title" data-i18n="s1title">Build</h2>
      <span class="service-subtitle" data-i18n="s1sub">From Groundwork to Handover</span>
      <p class="service-desc" data-i18n="s1desc">We manage the full construction process from site preparation through to final handover. Our build service coordinates every trade, supplier, and inspection &mdash; keeping your project on programme and on budget without compromise.</p>
      <ul class="service-includes">
        <li data-i18n="s1i1">Site preparation &amp; groundworks</li>
        <li data-i18n="s1i2">Structural &amp; civil works</li>
        <li data-i18n="s1i3">MEP coordination</li>
        <li data-i18n="s1i4">Construction management</li>
        <li data-i18n="s1i5">Final inspection &amp; handover</li>
      </ul>
      <a href="mailto:contact@helena.studio" class="service-cta" data-i18n="s1cta">Start a build</a>
    </div>
  </div>

  <div class="service-block">
    <div class="service-content">
      <span class="service-number">02</span>
      <h2 class="service-title" data-i18n="s2title">Design</h2>
      <span class="service-subtitle" data-i18n="s2sub">Architecture &middot; Interiors &middot; Technical</span>
      <p class="service-desc" data-i18n="s2desc">From concept to construction drawings, we develop designs that are as technically rigorous as they are considered. We handle everything from planning applications to detailed interior specifications, ready for immediate execution.</p>
      <ul class="service-includes">
        <li data-i18n="s2i1">Concept design &amp; feasibility</li>
        <li data-i18n="s2i2">Architectural drawings &amp; permits</li>
        <li data-i18n="s2i3">Interior spatial planning</li>
        <li data-i18n="s2i4">Technical specifications &amp; schedules</li>
      </ul>
      <a href="mailto:contact@helena.studio" class="service-cta" data-i18n="s2cta">Start a design</a>
    </div>
  </div>

  <div class="service-block">
    <div class="service-content">
      <span class="service-number">03</span>
      <h2 class="service-title" data-i18n="s3title">Project Management</h2>
      <span class="service-subtitle" data-i18n="s3sub">Planning &middot; Coordination &middot; Delivery</span>
      <p class="service-desc" data-i18n="s3desc">Not every project needs a full engagement. Our project management service provides focused oversight &mdash; programme planning, cost control, contractor management, and client reporting &mdash; at whatever level of involvement your project requires.</p>
      <ul class="service-includes">
        <li data-i18n="s3i1">Programme planning &amp; scheduling</li>
        <li data-i18n="s3i2">Budget control &amp; cost reporting</li>
        <li data-i18n="s3i3">Contractor &amp; supplier management</li>
        <li data-i18n="s3i4">Risk management &amp; progress reporting</li>
      </ul>
      <a href="mailto:contact@helena.studio" class="service-cta" data-i18n="s3cta">Talk to us</a>
    </div>
  </div>
</section>

<section class="about-section">
  <div class="section-header">
    <span class="section-label" data-i18n="about">About</span>
    <div class="section-rule"></div>
  </div>

  <div class="about-content">
    <div class="about-text">
      <p data-i18n="aboutP1">Helena is a build, design and project management firm founded on the principle that exceptional outcomes require exceptional coordination. We manage every phase of a project — from early design through to construction completion — with the same level of attention and discipline.</p>
      <p data-i18n="aboutP2">Our team brings together expertise across architecture, construction, and programme management. We work closely with clients, contractors, and consultants to ensure that every project is delivered on time, within budget, and to the highest standard.</p>
      <p data-i18n="aboutP3">Based in Geneva, we operate across Switzerland and internationally, delivering projects of all scales — from boutique commercial fit-outs to large mixed-use developments.</p>
    </div>
  </div>
</section>

<section class="articles-section">
  <div class="section-header">
    <span class="section-label" data-i18n="portfolio">Portfolio</span>
    <div class="section-rule"></div>
  </div>

  {% if collections.article.length %}
  <div class="articles-grid">
    {% for article in collections.article %}
    <a href="{{ article.url | url }}" class="article-card" data-article-key="{{ article.page.url }}">
      {% if article.data.tags %}
      <div class="card-tags">
        {% for tag in article.data.tags %}
          <span class="card-tag">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}

      <div class="card-title" data-card-field="title" data-orig="{{ article.data.title | escape }}">{{ article.data.title }}</div>

      {% if article.data.summary %}
      <div class="card-summary" data-card-field="summary" data-orig="{{ article.data.summary | escape }}">{{ article.data.summary }}</div>
      {% endif %}

      <div class="card-footer">
        <span class="card-date">{{ article.date | date("MMM dd, yyyy") }}</span>
        <span class="card-read" data-i18n="read">Read</span>
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <p class="empty-state">No articles yet — check back soon.</p>
  {% endif %}
</section>
<script>
window._articleTrans={
  {% for article in collections.article %}{% if article.data.translations %}{{ article.page.url | dump | safe }}:{{ article.data.translations | dump | safe }},{% endif %}{% endfor %}
};
</script>
