<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{% if summary %}{{ summary }}{% else %}{{ site.description }}{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #f9f7f3;
      --bg-warm:     #f3ede3;
      --bg-card:     #fffcf8;
      --accent:      #b8935a;
      --accent-rose: #c9a5a5;
      --accent-dim:  rgba(184, 147, 90, 0.09);
      --rose-dim:    rgba(201, 165, 165, 0.12);
      --text-1:      #1c1814;
      --text-2:      #6a5e54;
      --text-3:      #a8988a;
      --border:      rgba(184, 147, 90, 0.2);
      --border-rose: rgba(201, 165, 165, 0.25);
      --radius:      3px;
      --font-serif:  'Cormorant Garamond', Georgia, serif;
      --font-sans:   'Jost', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; font-size: 17px; }

    body {
      font-family: var(--font-sans);
      font-weight: 400;
      background-color: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    /* ── Decorative background ─────────────────────────── */
    .deco-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    /* Subtle architectural grid — like blueprint paper */
    .deco-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(184, 147, 90, 0.042) 1px, transparent 1px),
        linear-gradient(90deg, rgba(184, 147, 90, 0.042) 1px, transparent 1px);
      background-size: 72px 72px;
    }

    /* Radial wash so the grid fades from the centre outward */
    .deco-wash {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 75% 65% at 50% 10%, var(--bg) 0%, transparent 100%);
    }


    /* ── Layout ─────────────────────────────────────────── */
    .page-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ── Header ─────────────────────────────────────────── */
    header {
      padding: 2.25rem 0 2rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 2rem;
    }

    .site-title {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-1);
      text-decoration: none;
      transition: color 0.3s;
    }

    .site-title:hover { color: var(--accent); }

    .header-tagline {
      font-family: var(--font-sans);
      font-size: 0.68rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-3);
    }

    /* ── Main ───────────────────────────────────────────── */
    main {
      flex: 1;
      padding: 4rem 0 5rem;
    }

    /* ── Footer ─────────────────────────────────────────── */
    footer {
      padding: 1.75rem 0;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      color: var(--text-3);
      font-size: 0.72rem;
      font-weight: 300;
      letter-spacing: 0.12em;
    }

    footer a {
      color: var(--text-3);
      text-decoration: none;
      transition: color 0.25s;
    }

    footer a:hover { color: var(--accent); }

    /* ── Utilities ──────────────────────────────────────── */
    a { color: var(--accent); }

    :focus-visible {
      outline: 1px solid var(--accent);
      outline-offset: 4px;
    }

    /* ── Header right column ─────────────────────────────── */
    .header-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
    }

    /* ── Language switcher ────────────────────────────── */
    .lang-switcher {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .lang-btn {
      cursor: pointer;
      font-size: 1.4rem;
      line-height: 1;
      opacity: 0.35;
      transition: opacity 0.2s;
      background: none;
      border: none;
      padding: 1px;
      border-radius: 2px;
    }

    .lang-btn:hover { opacity: 0.7; }
    .lang-btn.active { opacity: 1; }

    /* PT-BR diagonal split flag */
    .flag-split {
      position: relative;
      width: 1.65rem;
      height: 1.35rem;
      overflow: hidden;
      border-radius: 2px;
      display: inline-block;
      vertical-align: middle;
      cursor: pointer;
      opacity: 0.35;
      transition: opacity 0.2s;
    }

    .flag-split:hover { opacity: 0.7; }
    .flag-split.active { opacity: 1; }

    .flag-split .fl, .flag-split .fr {
      position: absolute;
      font-size: 1.6rem;
      line-height: 1;
      top: -0.05rem;
      left: -0.05rem;
    }

    .flag-split .fl { clip-path: polygon(0 0, 100% 0, 0 100%); }
    .flag-split .fr { clip-path: polygon(100% 0, 100% 100%, 0 100%); }

    @media (max-width: 640px) {
      .page-wrap { padding: 0 1.25rem; }
      .header-tagline { display: none; }
      .lang-switcher { gap: 0.85rem; }
    }
  </style>
</head>
<body>
  <div class="deco-bg" aria-hidden="true">
    <div class="deco-grid"></div>
    <div class="deco-wash"></div>
  </div>

  <div class="page-wrap">
    <header>
      <a href="{{ '/' | url }}" class="site-title">{{ site.title }}</a>
      <div class="header-right">
        <span class="header-tagline" data-i18n="tagline">Interior Design &amp; Architecture</span>
        <div class="lang-switcher" role="group" aria-label="Language">
          <button class="lang-btn active" data-lang="en" title="English">&#x1F1EC;&#x1F1E7;</button>
          <button class="lang-btn" data-lang="fr" title="Fran&ccedil;ais">&#x1F1EB;&#x1F1F7;</button>
          <button class="lang-btn" data-lang="es" title="Espa&ntilde;ol">&#x1F1EA;&#x1F1F8;</button>
          <span class="flag-split" data-lang="ptbr" title="Portugu&ecirc;s" role="button" tabindex="0" aria-label="Português">
            <span class="fl">&#x1F1E7;&#x1F1F7;</span>
            <span class="fr">&#x1F1F5;&#x1F1F9;</span>
          </span>
        </div>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer>
      <span>&copy; {{ currentYear }} {{ site.title }}</span>
      <span data-i18n="tagline">Interior Design &amp; Architecture</span>
    </footer>
  </div>
  <script>
  (function(){
    var t={
      en:{tagline:'Interior Design & Architecture',heroLine1:'Spaces that',heroEm:'speak to the soul.',services:'Services',portfolio:'Portfolio',read:'Read',s1title:'Full Project',s1sub:'Design · Construction · Management',s1cta:'Start a project',s2title:'Turnkey Design',s2sub:'For Constructors & Developers',s2cta:'Work with us',s3title:'Consulting',s3sub:'Expert Guidance, On Demand',s3cta:'Book a session'},
      fr:{tagline:'Design d’intérieur & Architecture',heroLine1:'Des espaces qui',heroEm:'parlent à l’âme.',services:'Services',portfolio:'Portfolio',read:'Lire',s1title:'Projet Complet',s1sub:'Design · Construction · Gestion',s1cta:'Démarrer un projet',s2title:'Design Clé en Main',s2sub:'Pour Constructeurs & Promoteurs',s2cta:'Travailler avec nous',s3title:'Conseil',s3sub:'Expertise sur Mesure',s3cta:'Prendre rendez-vous'},
      es:{tagline:'Diseño de interiores & Arquitectura',heroLine1:'Espacios que',heroEm:'hablan al alma.',services:'Servicios',portfolio:'Portafolio',read:'Leer',s1title:'Proyecto Completo',s1sub:'Diseño · Construcción · Gestión',s1cta:'Iniciar un proyecto',s2title:'Diseño Llave en Mano',s2sub:'Para Constructores & Promotores',s2cta:'Trabajar con nosotros',s3title:'Consultoría',s3sub:'Orientación Experta',s3cta:'Reservar sesión'},
      ptbr:{tagline:'Design de interiores & Arquitectura',heroLine1:'Espaços que',heroEm:'falam à alma.',services:'Serviços',portfolio:'Portfólio',read:'Ler',s1title:'Projecto Completo',s1sub:'Design · Construção · Gestão',s1cta:'Iniciar um projecto',s2title:'Design Chave-na-Mão',s2sub:'Para Construtores & Promotores',s2cta:'Trabalhar connosco',s3title:'Consultoria',s3sub:'Orientação Especializada',s3cta:'Marcar sessão'}
    };
    function apply(lang){
      var d=t[lang]||t.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el){
        var k=el.dataset.i18n;
        if(d[k]!==undefined) el.textContent=d[k];
      });
      document.querySelectorAll('.lang-btn,.flag-split').forEach(function(el){
        el.classList.toggle('active',el.dataset.lang===lang);
      });
      localStorage.setItem('lang',lang);
      document.documentElement.lang=lang==='ptbr'?'pt-BR':lang;
    }
    document.querySelectorAll('.lang-btn,.flag-split').forEach(function(el){
      el.addEventListener('click',function(){ apply(el.dataset.lang); });
    });
    apply(localStorage.getItem('lang')||'en');
  })();
  </script>
</body>
</html>
