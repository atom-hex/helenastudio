<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{% if summary %}{{ summary }}{% else %}{{ site.description }}{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #f2ebe0;
      --bg-warm:     #e7dcc8;
      --bg-card:     #f7f1e8;
      --accent:      #8c5f18;
      --accent-rose: #9e5238;
      --accent-dim:  rgba(140, 95, 24, 0.08);
      --rose-dim:    rgba(158, 82, 56, 0.09);
      --text-1:      #0c0a07;
      --text-2:      #473a2c;
      --text-3:      #7a6a58;
      --border:      rgba(140, 95, 24, 0.18);
      --border-rose: rgba(158, 82, 56, 0.26);
      --radius:      2px;
      --font-serif:  'Cormorant Garamond', Georgia, serif;
      --font-sans:   'Jost', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; font-size: 19px; overflow-x: clip; }

    body {
      font-family: var(--font-sans);
      font-weight: 400;
      background-color: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
      overflow-x: clip;
      position: relative;
    }

    /* ── Decorative background ─────────────────────────── */
    .deco-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    /* Subtle architectural grid — like blueprint paper */
    .deco-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(140, 95, 24, 0.065) 1px, transparent 1px),
        linear-gradient(90deg, rgba(140, 95, 24, 0.065) 1px, transparent 1px);
      background-size: 52px 52px;
    }

    /* Radial wash so the grid fades from the centre outward */
    .deco-wash {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 75% 65% at 50% 10%, var(--bg) 0%, transparent 100%);
    }


    /* ── Layout ─────────────────────────────────────────── */
    :root { --page-pad: 2rem; }

    .page-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 var(--page-pad);
    }

    /* ── Header ─────────────────────────────────────────── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(242, 235, 224, 0.94);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      margin: 0 calc(-1 * var(--page-pad));
      padding-left: var(--page-pad);
      padding-right: var(--page-pad);
    }

    .header-left {
      display: flex;
      flex-direction: column;
    }

    .site-title {
      font-family: var(--font-serif);
      font-size: 2.6rem;
      font-weight: 300;
      letter-spacing: 0.38em;
      text-transform: uppercase;
      color: var(--text-1);
      text-decoration: none;
      transition: color 0.3s;
    }

    .site-title:hover { color: var(--accent); }

    .header-contact {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-3);
      text-decoration: none;
      margin-top: 0.25rem;
      transition: color 0.25s;
    }

    .header-contact:hover { color: var(--accent); }

    .header-tagline {
      font-family: var(--font-sans);
      font-size: 0.68rem;
      font-weight: 300;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-3);
    }

    /* ── Main ───────────────────────────────────────────── */
    main {
      flex: 1;
      padding: 4rem 0 5rem;
    }

    /* ── Footer ─────────────────────────────────────────── */
    footer {
      padding: 1.75rem 0;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      color: var(--text-3);
      font-size: 0.72rem;
      font-weight: 300;
      letter-spacing: 0.12em;
    }

    footer a {
      color: var(--text-3);
      text-decoration: none;
      transition: color 0.25s;
    }

    footer a:hover { color: var(--accent); }

    /* ── Utilities ──────────────────────────────────────── */
    a { color: var(--accent); }

    :focus-visible {
      outline: 1px solid var(--accent);
      outline-offset: 4px;
    }

    /* ── Header right column ─────────────────────────────── */
    .header-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
    }

    /* ── Language switcher ────────────────────────────── */
    .lang-switcher {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .lang-btn {
      cursor: pointer;
      font-size: 1.4rem;
      line-height: 1;
      opacity: 0.35;
      transition: opacity 0.2s;
      background: none;
      border: none;
      padding: 1px;
      border-radius: 2px;
    }

    .lang-btn:hover { opacity: 0.7; }
    .lang-btn.active { opacity: 1; }

    /* PT-BR diagonal split flag */
    .flag-split {
      position: relative;
      width: 1.65rem;
      height: 1.35rem;
      overflow: hidden;
      border-radius: 2px;
      display: inline-block;
      vertical-align: middle;
      cursor: pointer;
      opacity: 0.35;
      transition: opacity 0.2s;
    }

    .flag-split:hover { opacity: 0.7; }
    .flag-split.active { opacity: 1; }

    .flag-split .fl, .flag-split .fr {
      position: absolute;
      font-size: 1.6rem;
      line-height: 1;
      top: -0.05rem;
      left: -0.05rem;
    }

    .flag-split .fl { clip-path: polygon(0 0, 100% 0, 0 100%); }
    .flag-split .fr { clip-path: polygon(100% 0, 100% 100%, 0 100%); }

    @media (max-width: 640px) {
      :root { --page-pad: 0.85rem; }
      header { padding-top: 0.85rem; padding-bottom: 0.85rem; gap: 0.75rem; }
      .site-title { font-size: 1.05rem; letter-spacing: 0.22em; }
      .header-contact { font-size: 0.55rem; }
      .header-tagline { display: none; }
      .lang-btn { font-size: 1.1rem; }
      .flag-split { font-size: 1.1rem; width: 1.1rem; height: 1.1rem; }
      .lang-switcher { gap: 0.6rem; }
    }
  </style>
</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2MYS3B3VSE"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-2MYS3B3VSE');
</script>
<body>
  <div class="deco-bg" aria-hidden="true">
    <div class="deco-grid"></div>
    <div class="deco-wash"></div>
  </div>

  <div class="page-wrap">
    <header>
      <div class="header-left">
        <a href="{{ '/' | url }}" class="site-title">{{ site.title }}</a>
        <a href="mailto:contact@helena.studio" class="header-contact">contact@helena.studio</a>
      </div>
      <div class="header-right">
        <span class="header-tagline" data-i18n="tagline">Build · Design · Project Management</span>
        <div class="lang-switcher" role="group" aria-label="Language">
          <button class="lang-btn active" data-lang="en" title="English">&#x1F1EC;&#x1F1E7;</button>
          <button class="lang-btn" data-lang="fr" title="Fran&ccedil;ais">&#x1F1EB;&#x1F1F7;</button>
          <button class="lang-btn" data-lang="es" title="Espa&ntilde;ol">&#x1F1EA;&#x1F1F8;</button>
          <span class="flag-split" data-lang="ptbr" title="Portugu&ecirc;s" role="button" tabindex="0" aria-label="Português">
            <span class="fl">&#x1F1E7;&#x1F1F7;</span>
            <span class="fr">&#x1F1F5;&#x1F1F9;</span>
          </span>
        </div>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer>
      <span>&copy; {{ currentYear }} {{ site.title }}</span>
      <span data-i18n="tagline">Build · Design · Project Management</span>
    </footer>
  </div>
  <script>
