      }
    };
    function apply(lang){
      var d=t[lang]||t.en;
      document.querySelectorAll('[data-i18n]').forEach(function(el){
        var k=el.dataset.i18n;
        if(d[k]!==undefined) el.textContent=d[k];
      });
      if(window._artLangs){
        var artTr=window._artLangs[lang]||window._artLangs.en;
        var titleEl=document.querySelector('.article-title');
        var summEl=document.querySelector('.article-summary');
        if(titleEl&&artTr.title)titleEl.textContent=artTr.title;
        if(summEl&&artTr.summary)summEl.textContent=artTr.summary;
        document.querySelectorAll('.article-body').forEach(function(b){b.hidden=true;});
        var body=document.getElementById('article-body-'+lang)||document.getElementById('article-body-en');
        if(body)body.hidden=false;
      }
      document.querySelectorAll('[data-article-key]').forEach(function(card){
        var url=card.dataset.articleKey;
        var tr=lang!=='en'&&window._articleTrans&&window._articleTrans[url]&&window._articleTrans[url][lang];
        var t=card.querySelector('[data-card-field="title"]');
        var s=card.querySelector('[data-card-field="summary"]');
        if(t)t.textContent=tr&&tr.title?tr.title:(t.dataset.orig||t.textContent);
        if(s)s.textContent=tr&&tr.summary?tr.summary:(s.dataset.orig||s.textContent);
      });
      document.querySelectorAll('.lang-btn,.flag-split').forEach(function(el){
        el.classList.toggle('active',el.dataset.lang===lang);
      });
      localStorage.setItem('lang',lang);
      document.documentElement.lang=lang==='ptbr'?'pt-BR':lang;
    }
    document.querySelectorAll('.lang-btn,.flag-split').forEach(function(el){
      el.addEventListener('click',function(){ apply(el.dataset.lang); });
    });
    apply(localStorage.getItem('lang')||'en');
  })();
  </script>
</body>
</html>
