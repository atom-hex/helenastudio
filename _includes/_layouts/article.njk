---
layout: _layouts/base.njk
---
<style>
  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.25s;
  }

  .article-back:hover { color: var(--accent); }

  .article-back svg {
    width: 12px; height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-rose);
    border: 1px solid var(--border-rose);
    padding: 0.2rem 0.65rem;
    border-radius: 1px;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--text-1);
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .article-meta {
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .article-contact {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-1);
    text-decoration: none;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--accent);
    transition: color 0.25s, letter-spacing 0.35s ease;
    margin-top: 1rem;
  }

  .article-contact:hover {
    color: var(--accent);
    letter-spacing: 0.28em;
  }

  .article-summary {
    margin-top: 1.25rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--text-2);
    line-height: 1.65;
  }

  /* ── Prose ─────────────────────────────────────────── */
  .article-body {
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.85;
    color: var(--text-2);
    letter-spacing: 0.01em;
  }

  .article-body h2 {
    font-family: var(--font-serif);
    font-size: 1.65rem;
    font-weight: 400;
    color: var(--text-1);
    margin: 3rem 0 0.85rem;
    letter-spacing: 0.02em;
  }

  .article-body h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-1);
    margin: 2.25rem 0 0.6rem;
  }

  .article-body p { margin-bottom: 1.4rem; }

  .article-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(184, 147, 90, 0.3);
    transition: text-decoration-color 0.25s;
  }

  .article-body a:hover { text-decoration-color: var(--accent); }

  .article-body ul, .article-body ol {
    padding-left: 1.5rem;
    margin-bottom: 1.4rem;
  }

  .article-body li { margin-bottom: 0.5rem; }

  .article-body blockquote {
    margin: 2.5rem 0;
    padding: 1.5rem 2rem;
    border-left: 2px solid var(--accent);
    background: var(--accent-dim);
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 300;
    color: var(--text-1);
    line-height: 1.65;
  }

  .article-body hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  .article-body img {
    display: block;
    width: 100%;
    max-width: none;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .article-body code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
    background: var(--bg-warm);
    color: var(--text-2);
    padding: 0.15em 0.4em;
    border-radius: 2px;
    border: 1px solid var(--border);
  }

  .article-body pre {
    background: var(--bg-warm);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .article-body pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }
</style>

<article>
  <div class="article-header">
    <a href="{{ '/' | url }}" class="article-back">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      Portfolio
    </a>

    {% if tags %}
    <div class="article-tags">
      {% for tag in tags %}
        <span class="tag">{{ tag }}</span>
      {% endfor %}
    </div>
    {% endif %}

    <h1 class="article-title" data-orig="{{ title | escape }}">{{ title }}</h1>

    <div class="article-meta">{{ page.date | date("LLLL dd, yyyy") }}</div>

    <a href="mailto:hello@helena.studio" class="article-contact">hello@helena.studio</a>

    {% if summary %}
    <p class="article-summary" data-orig="{{ summary | escape }}">{{ summary }}</p>
    {% endif %}
  </div>

  <div class="article-body" id="article-body-en">
    {{ content | safe }}
  </div>
  {% if translations %}
    {% for lang, trans in translations %}
  <div class="article-body" id="article-body-{{ lang }}" hidden>{{ trans.body | safe }}</div>
    {% endfor %}
  {% endif %}
  <script>
  window._artLangs={en:{title:{{ title | dump | safe }},summary:{{ summary | dump | safe }}}{% if translations %}{% for lang, trans in translations %},{{ lang | dump | safe }}:{title:{{ trans.title | dump | safe }},summary:{{ trans.summary | dump | safe }}}{% endfor %}{% endif %}};
  window._artUrl={{ page.url | dump | safe }};
  </script>
</article>
